# App URLs
PUBLIC_BASE_URL=
FRONTEND_ORIGIN=http://localhost:3000
CHATGPT_RETURN_URL=https://chatgpt.com
OAUTH_AUTHORIZATION_URL=https://mcp.justinnwajei.com/oauth/authorize
OAUTH_TOKEN_URL=https://mcp.justinnwajei.com/oauth/token
OAUTH_TRANSACTION_SECRET=
# Shared only between the backend and the Next.js server. Use a distinct random secret.
ONBOARDING_ASSERTION_SECRET=
ONBOARDING_ASSERTION_ISSUERS=https://agentic-forex-app.vercel.app,http://localhost:3000
# Optional compatibility fallback; CIMD clients do not need to appear here.
OAUTH_ALLOWED_CLIENT_IDS=
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=7776000

# Database
DATABASE_URL=

# OAuth / MCP auth
MCP_REQUIRE_OAUTH=true
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URL=

# Credential encryption
BROKER_SECRET_KEY=

# TradeLocker / market data
MARKET_DATA_PROVIDER=
ALLOW_ENV_BROKER_FALLBACK=
TRADELOCKER_CONFIG_CACHE_TTL_SECONDS=900
TRADELOCKER_DEMO_BASE_URL=https://demo.tradelocker.com/backend-api
AUTONOMOUS_SNAPSHOT_TTL_SECONDS=60
AUTONOMOUS_PREVIEW_TTL_SECONDS=60
AUTONOMOUS_QUOTE_MAX_AGE_SECONDS=30
AUTONOMOUS_PRICE_TOLERANCE_PERCENT=0.25
AUTONOMOUS_MAX_SPREAD_PIPS=3.0
AUTONOMOUS_NEWS_BLACKOUT_MINUTES=30
# Autonomous decisions fail closed and ChatGPT uses these server-side defaults.
AUTONOMOUS_DECISION_PROVIDER=no_trade
AUTONOMOUS_DECISION_MODEL=gpt-5.6
AUTONOMOUS_DECISION_TIMEOUT_SECONDS=30
AUTONOMOUS_DECISION_MAX_RETRIES=1
AUTONOMOUS_DECISION_MAX_INPUT_CHARS=80000
AUTONOMOUS_DEFAULT_MINIMUM_CONFIDENCE=0.70
AUTONOMOUS_MAX_ARMING_HOURS=24
OPENAI_API_KEY=
AUTONOMOUS_SCHEDULER_POLL_SECONDS=30
AUTONOMOUS_SCHEDULER_LEASE_SECONDS=180
AUTONOMOUS_SCHEDULER_BATCH_SIZE=20
AUTONOMOUS_SCHEDULER_MAX_RETRIES=2
AUTONOMOUS_SCHEDULER_RETRY_BASE_SECONDS=30
AUTONOMOUS_SCHEDULER_RETRY_CAP_SECONDS=300
AUTONOMOUS_SCHEDULER_HEARTBEAT_STALE_SECONDS=120
AUTONOMOUS_SCHEDULER_REQUIRED_FOR_READINESS=false
AUTONOMOUS_SCHEDULER_EMBEDDED=false

# Finnhub (optional public calendar/news/secondary context)
FINNHUB_ENABLED=false
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_TIMEOUT_SECONDS=15
FINNHUB_MAX_RETRIES=2
FINNHUB_CACHE_TTL_SECONDS=300

# FRED / ALFRED (optional official macro history and revisions)
FRED_ENABLED=false
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_TIMEOUT_SECONDS=15
FRED_MAX_RETRIES=2
FRED_CACHE_TTL_SECONDS=3600
# JSON object mapping currency codes to verified FRED series IDs. No defaults are assumed.
MACRO_CATALOG_JSON={}

# Market-data response and retrieval limits
MARKET_DATA_DEFAULT_CANDLES=300
MARKET_DATA_MAX_RESPONSE_CANDLES=2000
MARKET_DATA_MAX_RETRIEVAL_CANDLES=10000
MARKET_DATA_MAX_PAGES=50
MARKET_SERIES_CACHE_TTL_SECONDS=600
MARKET_SERIES_CACHE_MAX_ITEMS=100

# Optional untrusted TradingView alert ingress
TRADINGVIEW_WEBHOOK_SECRET=

# Legacy safety flags
LIVE_TRADING_ENABLED=false
KILL_SWITCH_ENABLED=true
