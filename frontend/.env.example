# Auth0 frontend web app
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=

# Backend API access
AUTH0_AUDIENCE=
# Keep the existing public variable name. In production this must be the HTTPS API
# origin, never localhost and never the Vercel frontend origin.
NEXT_PUBLIC_API_BASE_URL=
# Optional server-log diagnostics contain only config booleans, hostname, path,
# method, status, and a sanitized failure category. They never include tokens.
BACKEND_DIAGNOSTICS_ENABLED=false
ONBOARDING_ASSERTION_SECRET=
ONBOARDING_ASSERTION_AUDIENCE=https://mcp.justinnwajei.com

# Backend OAuth metadata must advertise this frontend route as its authorization endpoint
# OAUTH_AUTHORIZATION_URL=https://your-frontend.example/oauth/authorize (backend setting)
